classDiagram
direction TB

%% ── Swing host ──────────────────────────────────────────────
class GamePanel {
  +State state
  -GameWorld world
  -UiSelectionState uiState
  -GameRenderer renderer
  -GameEngine engine
  -long lastUpdate
  -long pauseStart
  +startGame()
  +enterPauseMenu()
  +resumeFromPause()
  +endGameFromPauseAsLose()
  +handleKey(KeyEvent)
}

class GameEngine {
  -GamePanel panel
  -GameWorld world
  -Timer timer
  +start()
  +stop()
  -tick()
}

class GameRenderer {
  -GameWorld world
  -UiSelectionState ui
  +render(Graphics2D, State)
  -drawMenu(Graphics2D)
  -drawGame(Graphics2D)
  -drawShop(Graphics2D)
  -drawHUD(Graphics2D)
  -drawPauseOverlay(Graphics2D)
  -drawEndScreen(Graphics2D, boolean)
}

class GameInputListener {
  -GamePanel panel
  -GameWorld world
  -UiSelectionState ui
  +mouseClicked(MouseEvent)
  +mousePressed(MouseEvent)
  +mouseMoved(MouseEvent)
}

class UiSelectionState {
  -PlantType selectedPlant
  -int hoverCol
  -int hoverRow
  -int selectedTileCol
  -int selectedTileRow
  -Rectangle removeBtnBounds
  -Point mousePos
  +getSelectedPlant() PlantType
  +setSelectedPlant(PlantType)
  +setHoverColRow(int, int)
  +setSelectedTile(int, int)
  +setRemoveBtnBounds(Rectangle)
  +setMousePos(Point)
  +clearSelectedPlant()
}

class UiLayout {
  <<utility>>
  +menuStartButton()$ Rectangle
  +endScreenRestartButton()$ Rectangle
  +endScreenMenuButton()$ Rectangle
  +pauseContinueButton()$ Rectangle
  +pauseRestartButton()$ Rectangle
  +pauseEndButton()$ Rectangle
}

class Constants {
  <<constants>>
  +WINDOW_WIDTH$ int
  +WINDOW_HEIGHT$ int
  +COLS$ int
  +ROWS$ int
  +CELL_W$ int
  +CELL_H$ int
  +SUN_VALUE$ int
  +PEA_DMG$ int
  +SNOW_PEA_DMG$ int
  +CHERRY_DMG$ int
  +CHERRY_FUSE$ int
  +ZOMBIE_SPEED$ int
}

%% ── Model ───────────────────────────────────────────────────
class GameWorld {
  +Plant[][] grid
  +List~Zombie~ zombies
  +List~Pea~ peas
  +List~Sun~ suns
  +List~Explosion~ explosions
  +List~FloatText~ floatTexts
  +int sunCount
  +int wave
  +int maxWaves
  +int zombiesKilled
  +start()
  +update(double) UpdateResult
  +hasZombieInRow(int, int) boolean
  +explodeCherry(Plant)
  +removePlant(int, int)
  +addFloatText(String, int, int, Color, int, int)
}

%% ── Plant hierarchy ─────────────────────────────────────────
class Plant {
  <<abstract>>
  +PlantType type
  +int col
  +int row
  +int hp
  +int baseHp
  +int baseAttack
  +char idChar
  +long lastShootTime
  +long lastSunTime
  +boolean exploding
  +isDead() boolean
  +cx() int
  +cy() int
  +update(GameWorld, long)*
  +draw(Graphics2D)*
  #drawHpBar(Graphics2D)
}

class Sunflower {
  +update(GameWorld, long)
  +draw(Graphics2D)
}

class Peashooter {
  +update(GameWorld, long)
  +draw(Graphics2D)
}

class SnowPea {
  +update(GameWorld, long)
  +draw(Graphics2D)
}

class Wallnut {
  +draw(Graphics2D)
}

class CherryBomb {
  +update(GameWorld, long)
  +draw(Graphics2D)
}

class PlantType {
  <<enumeration>>
  SUNFLOWER
  PEASHOOTER
  WALLNUT
  SNOWPEA
  CHERRYBOMB
  +String name
  +int cost
  +int maxHp
  +Color color
  +create(int, int)* Plant
}

%% ── Zombie hierarchy ────────────────────────────────────────
class Zombie {
  <<abstract>>
  +int row
  +double x
  +int hp
  +int maxHp
  +int level
  +double speedFactor
  +long slowUntil
  +boolean attacking
  -globalHpBonus$ int
  +isDead() boolean
  +update(double)
  +attackPower() int
  +draw(Graphics2D)*
  #drawHpBar(Graphics2D)
  #drawLegsAndShoes(Graphics2D, int, int, Color, int)
  #drawShadow(Graphics2D, int, int)
  +resetGlobalHpBonus()$
  +addGlobalHpBonus(int)$
}

class NormalZombie {
  +draw(Graphics2D)
}

class FastZombie {
  +draw(Graphics2D)
}

class TankZombie {
  +draw(Graphics2D)
}

class CherryZombie {
  +draw(Graphics2D)
}

class ZombieType {
  <<enumeration>>
  NORMAL
  FAST
  TANK
  CHERRY
  +char idChar
  +int baseHp
  +double baseSpeed
  +create(int, int)* Zombie
}

%% ── Game object value types ─────────────────────────────────
class Pea {
  +double x
  +double y
  +int row
  +boolean frozen
  +boolean dead
  +update(double)
  +getBounds() Rectangle
  +draw(Graphics2D)
}

class Sun {
  +double x
  +double y
  +boolean falling
  +boolean collected
  +update(double)
  +isExpired() boolean
  +getBounds() Rectangle
  +draw(Graphics2D)
}

class Explosion {
  +double x
  +double y
  +int radius
  +boolean done
  +update(double)
  +draw(Graphics2D)
}

class FloatText {
  +String text
  +double x
  +double y
  +Color color
  +long expireTime
  +draw(Graphics2D)
}

%% ── Relationships ───────────────────────────────────────────

%% GamePanel composition
GamePanel "1" *-- "1" GameWorld
GamePanel "1" *-- "1" UiSelectionState
GamePanel "1" *-- "1" GameRenderer
GamePanel "1" *-- "1" GameEngine
GamePanel "1" *-- "1" GameInputListener

%% Engine / renderer / input wiring
GameEngine --> GamePanel : controls
GameRenderer --> GameWorld : reads
GameRenderer --> UiSelectionState : reads
GameRenderer ..> UiLayout : uses
GameInputListener --> GameWorld : mutates
GameInputListener --> UiSelectionState : owns
GameInputListener ..> UiLayout : uses

%% GameWorld aggregates game objects
GameWorld "1" o-- "0..*" Pea
GameWorld "1" o-- "0..*" Sun
GameWorld "1" o-- "0..*" Explosion
GameWorld "1" o-- "0..*" FloatText
GameWorld "1" o-- "0..*" Zombie
GameWorld "1" *-- "0..45" Plant

%% Plant hierarchy
Plant <|-- Sunflower
Plant <|-- Peashooter
Plant <|-- SnowPea
Plant <|-- Wallnut
Plant <|-- CherryBomb
Plant --> PlantType : type
Plant ..> GameWorld : update uses

%% PlantType factory
PlantType ..> Plant : creates

%% Zombie hierarchy
Zombie <|-- NormalZombie
Zombie <|-- FastZombie
Zombie <|-- TankZombie
Zombie <|-- CherryZombie
ZombieType ..> Zombie : creates